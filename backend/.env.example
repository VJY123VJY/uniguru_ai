# UniGuru Backend Environment Configuration

# Server Configuration
UNIGURU_HOST=0.0.0.0
UNIGURU_PORT=8000

# Authentication
UNIGURU_API_AUTH_REQUIRED=true
UNIGURU_API_TOKEN=UG_x8K29dkL92msPq
UNIGURU_API_TOKENS=UG_9xK2mPq1,UG_a8Hj92Lp,UG_zX91QwEr
UNIGURU_ALLOWED_CALLERS=bhiv-assistant,gurukul-platform,internal-testing,uniguru-frontend

# LLM Configuration (local Ollama — no external API keys required)
UNIGURU_LLM_URL=http://localhost:11434/api/generate
UNIGURU_LLM_MODEL=llama2
UNIGURU_LLM_TIMEOUT_SECONDS=30
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=30
UNIGURU_OLLAMA_ENABLED=true

# Retrieval thresholds
UNIGURU_KB_CONFIDENCE_THRESHOLD=0.30
UNIGURU_KB_CONFIDENCE_MIN=0.30
UNIGURU_KOSHA_CONFIDENCE_MIN=0.15
UNIGURU_FAISS_SCORE_MIN=0.35
UNIGURU_EMBEDDING_MODEL=all-MiniLM-L6-v2
UNIGURU_RETRIEVAL_CACHE_TTL=3600
UNIGURU_LOG_LEVEL=INFO

# Router Safety Controls
UNIGURU_ROUTER_QUEUE_LIMIT=100
UNIGURU_ROUTER_LATENCY_THRESHOLD_MS=5000
UNIGURU_ROUTER_CIRCUIT_OPEN_SECONDS=60
UNIGURU_ROUTER_UNVERIFIED_FALLBACK=true

# Feature Flags
ENABLE_BUCKET_TELEMETRY=false
ENABLE_CORE_READER=false
ENABLE_STT=true

# Knowledge Base Paths
KB_BASE_PATH=./knowledge

# Logging
LOG_LEVEL=INFO
